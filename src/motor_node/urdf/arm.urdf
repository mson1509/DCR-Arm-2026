<robot name="robot_arm">
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.050" radius="0.1"/>
            </geometry>
        </visual>	
    </link>
    
    <!-- Joint 1: base_joint | range: -185 to 185 deg -->
    <joint name="base_joint" type="revolute">
        <parent link="base_link"/>
        <child link="base_rot"/>
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <axis xyz="0 0 -1"/>
        <limit lower="-3.2288" upper="3.2288" effort="100" velocity="1.0"/>
    </joint>

    <link name="base_rot">
        <visual>
            <origin xyz="0 0 0.035" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.07" />
            </geometry>
        </visual>	
    </link>

    <!-- Joint 2: shoulder_joint | range: -5 to 185 deg -->
    <joint name="shoulder_joint" type="revolute">
        <parent link="base_rot"/>
        <child link="arm1"/>
        <origin xyz="0 0 0.07" rpy="-1.57 0 0" />
        <axis xyz="1 0 0"/>
        <limit lower="-0.0873" upper="3.2288" effort="100" velocity="1.0"/>
    </joint>

    <link name="arm1">
        <visual>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.5" radius="0.02"/>
            </geometry>
        </visual>	
    </link>

    <!-- Joint 3: elbow_joint | range: -5 to 275 deg -->
    <joint name="elbow_joint" type="revolute">
        <parent link="arm1"/>
        <child link="arm2"/>
        <origin xyz="0.08 0 0.5" rpy="3.14 0 0" />
        <axis xyz="-1 0 0"/>
        <limit lower="-0.0873" upper="4.7997" effort="100" velocity="1.0"/>
    </joint>
    
    <link name="arm2">
        <visual>
            <origin xyz="0 0 0.275" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.55" radius="0.02"/>
            </geometry>
        </visual>	
    </link>

    <!-- Joint 4: yaw_joint | range: -95 to 185 deg -->
    <joint name="yaw_joint" type="revolute">
        <parent link="arm2"/>
        <child link="yaw"/>
        <origin xyz="0 0.05 0.6" rpy="0 0 0" />
        <axis xyz="0 -1 0"/>
        <limit lower="-1.6581" upper="3.2288" effort="100" velocity="1.0"/>
    </joint>

    <link name ="yaw">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
        </visual>	
    </link>

    <!-- Joint 5: pitch_joint | range: -5 to 275 deg -->
    <joint name="pitch_joint" type="revolute">
        <parent link="yaw"/>
        <child link="pitch"/>
        <origin xyz="-0.05 0.05 0" rpy="0 0 0" />
        <axis xyz="1 0 0"/>
        <limit lower="-0.0873" upper="4.7997" effort="100" velocity="1.0"/>
    </joint>

    <link name ="pitch">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
        </visual>	
    </link>

    <!-- Joint 6: roll_joint | range: -185 to 185 deg -->
    <joint name="roll_joint" type="revolute">
        <parent link="pitch"/>
        <child link="roll"/>
        <origin xyz="0 0 -0.075" rpy="0 0 0" />
        <axis xyz="0 0 1"/>
        <limit lower="-3.2288" upper="3.2288" effort="100" velocity="1.0"/>
    </joint>

    <link name ="roll">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
        </visual>	
    </link>
    
    <joint name="ee_joint" type="fixed">
        <parent link="roll"/>
        <child link="ee_link"/>
        <origin xyz="0 0 -0.1" rpy="0 0 0"/>
    </joint>

    <link name="ee_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.15" />
            </geometry>
        </visual>
    </link>

</robot>