<robot name="robot_arm">
 	<link name="base_link">
		<visual>
		    <origin xyz="0 0 0.025" rpy="0 0 0"/>
			<geometry>
				<cylinder length="0.050" radius="0.1"/>
			</geometry>
		</visual>	
	</link>
    
    <joint name="base_joint" type="revolute">
      <parent link="base_link"/>
      <child link="base_rot"/>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <axis xyz="0 0 1"/>
      <limit lower="-6.28" upper="6.28" />
    </joint>

    <link name="base_rot">
		<visual>
      <origin xyz="0 0 0.035" rpy="0 0 0" />
          	<geometry>
                <box size="0.1 0.1 0.07" />
			</geometry>
		</visual>	
	</link>

      <joint name="shoulder_joint" type="revolute">
      <parent link="base_rot"/>
      <child link="arm1"/>
      <origin xyz="0 0 0.07" rpy="-1.57 0 0" />
      <axis xyz="1 0 0"/>
      <limit lower="0" upper="3.14" />
    </joint>

    <link name="arm1">
		<visual>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</visual>	
	</link>

    <joint name="elbow_joint" type="revolute">
      <parent link="arm1"/>
      <child link="arm2"/>
      <origin xyz="0.08 0 0.5" rpy="3.14 0 0" />
      <axis xyz="-1 0 0"/>
        <limit lower="-6.28" upper="6.28" />
    </joint>
    
    <link name="arm2">
		<visual>
          <origin xyz="0 0 0.25" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.5" radius="0.02"/>
			</geometry>
		</visual>	
  </link>

    <joint name="ee_joint" type="fixed">
    <parent link="arm2"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <link name="ee_link">
		<visual>
          <origin xyz="0 0 0.025" rpy="0 0 0" />
          	<geometry>
            	<box size="0.1 0.1 0.05" />
			</geometry>
		</visual>	
    </link>

</robot>